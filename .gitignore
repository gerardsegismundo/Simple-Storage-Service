# Terraform local state and plugin cache
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.backup

# Terraform variable files (may contain secrets/values)
terraform/*.tfvars

# Generated Lambda package
lambda/*.zip
*/__pycache__/
*.pyc

# Script artefacts (keep scripts in git, ignore generated output)
*.log

# Editor files
*.swp
*.swo
.DS_Store
Thumbs.db
